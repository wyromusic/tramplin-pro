# ================================================
# tramplin-pro — Environment Variables
# Скопируй в .env.local и заполни значения
# ================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://znuquyllsrbpijbgymih.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # Settings → API Keys → anon public
SUPABASE_SERVICE_ROLE_KEY=         # Settings → API Keys → service_role (SECRET!)

# --- ЮKassa ---
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_WEBHOOK_SECRET=

# --- SMS (SMSC.ru) ---
SMSC_LOGIN=
SMSC_PASSWORD=

# --- Web Push (VAPID) ---
# Генерация: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@tramplin.pro

# --- App ---
NEXT_PUBLIC_BASE_URL=https://tramplin.pro

